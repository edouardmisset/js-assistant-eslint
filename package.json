{
  "name": "@upfluence/eslint-config-js-assistant",
  "version": "0.1.0",
  "description": "Shared ESLint flat config that captures the reusable JS/TS parts of P42 JS Assistant.",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "docs",
    "data",
    "README.md"
  ],
  "scripts": {
    "build:docs": "node scripts/build-docs.mjs",
    "check": "node --check src/index.js && node --check data/rule-matrix.mjs && node --check scripts/build-docs.mjs",
    "lint:self": "eslint src scripts data --max-warnings=0"
  },
  "peerDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-de-morgan": "^2.1.2",
    "eslint-plugin-sonarjs": "^3.0.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "typescript": ">=5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-de-morgan": "^2.1.2",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^70.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
